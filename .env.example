# MongoDB
MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pm_prod?retryWrites=true&w=majority

# Clerk (use dev instance for local/preview, prod instance for production)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
CLERK_WEBHOOK_SIGNING_SECRET=whsec_...

# Upstash Redis (HTTP REST API)
UPSTASH_REDIS_REST_URL=https://your-redis.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_token

# GitHub Webhook (shared secret for v1 single-repo webhooks)
GITHUB_WEBHOOK_SECRET=your_webhook_secret

# Optional: separate preview database
# MONGODB_URI=mongodb+srv://user:password@cluster.mongodb.net/pm_preview?retryWrites=true&w=majority
